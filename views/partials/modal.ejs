<div class="modal-overlay" id="getStartedModal">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title">Get Started with Tak2ai</h3>
      <p class="modal-subtitle">Tell us about your business and we'll find the perfect AI solution.</p>
      <button class="modal-close" id="modalClose" aria-label="Close modal">&times;</button>
    </div>
    <form class="modal-form" id="leadForm" action="/api/leads" method="POST">
      <div class="form-group">
        <label for="leadName">Full Name <span class="required">*</span></label>
        <input type="text" id="leadName" name="name" placeholder="John Doe" required>
      </div>
      <div class="form-group">
        <label for="leadEmail">Email <span class="required">*</span></label>
        <input type="email" id="leadEmail" name="email" placeholder="john@example.com" required>
      </div>
      <div class="form-group">
        <label for="leadPhone">Phone <span class="required">*</span></label>
        <input type="tel" id="leadPhone" name="phone" placeholder="+91 98765 43210" required>
      </div>
      <div class="form-group">
        <label for="leadCategory">Your Business Category <span class="required">*</span></label>
        <select id="leadCategory" name="category" required>
          <option value="" disabled selected>Business Category</option>
          <option>Travel &amp; Tourism</option>
          <option>School</option>
          <option>Telecommunications</option>
          <option>Jewellery</option>
          <option>Manufacturing</option>
          <option>IT &amp; ITES</option>
          <option>Shops &amp; Showrooms</option>
          <option>Automobile Sales</option>
          <option>Automobile Service</option>
          <option>Life Insurance</option>
          <option>Health Insurance</option>
          <option>Astrology</option>
          <option>Solicitor Firm</option>
          <option>Sports</option>
          <option>Driver Centre</option>
          <option>Nursing Centre</option>
          <option>Garments</option>
          <option>Mobile Sales &amp; Service</option>
          <option>Digital Marketing</option>
          <option>Banquet Hall</option>
          <option>Wedding Planners</option>
          <option>Decorators</option>
          <option>Catering Services</option>
          <option>Production House</option>
          <option>Clubs &amp; Memberships</option>
          <option>House Keeping Agency</option>
          <option>Security Guard</option>
        </select>
      </div>
      <div class="form-group">
        <label for="leadMessage">Message (optional)</label>
        <textarea id="leadMessage" name="message" rows="3" placeholder="Tell us about your automation needs..."></textarea>
      </div>
      <div class="otp-section" id="otpSection">
        <p>We've sent a 6-digit code to <strong id="otpPhoneDisplay"></strong></p>
        <div class="otp-row">
          <input type="text" id="otpInput" maxlength="6" inputmode="numeric" pattern="[0-9]*" placeholder="Enter OTP" autocomplete="one-time-code">
          <button type="button" class="btn btn-primary otp-btn" id="otpVerifyBtn">Verify</button>
        </div>
        <div class="otp-error" id="otpError"></div>
        <div class="otp-countdown" id="otpCountdown">
          Didn't receive? <a id="otpResend">Resend</a>
        </div>
      </div>
      <button type="submit" class="btn btn-primary btn-block modal-submit">
        <span class="modal-submit-text">Submit</span>
        <span class="modal-submit-loader" style="display:none"><i data-lucide="loader-2" class="spin"></i></span>
      </button>
      <p class="form-footnote">We'll get back to you within 24 hours. No spam, ever.</p>
    </form>
  </div>
</div>
