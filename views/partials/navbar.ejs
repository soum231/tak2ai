<header class="nav" id="nav">
  <div class="nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Tak2ai Home">
      <img src="/assets/final logo dark.png" alt="Tak2ai" class="nav-logo-img">
    </a>

    <!-- Desktop nav links -->
    <nav class="nav-links" id="navLinks">
      <a href="/" class="nav-link <%= currentPage === 'home' ? 'active' : '' %>">Home</a>
      <div class="nav-dd">
        <button class="nav-link nav-dd-trigger" aria-haspopup="true">
          Services <i data-lucide="chevron-down" class="nav-dd-icon"></i>
        </button>
        <div class="nav-dd-menu">
          <a href="/voice-ai" class="nav-link <%= currentPage === 'voice-ai' ? 'active' : '' %>">
            <i data-lucide="phone" class="nav-dd-item-icon"></i> AI Voice Calling
          </a>
          <a href="/chatbot" class="nav-link <%= currentPage === 'chatbot' ? 'active' : '' %>">
            <i data-lucide="bot" class="nav-dd-item-icon"></i> AI Chatbot
          </a>
          <a href="/video-ai" class="nav-link <%= currentPage === 'video-ai' ? 'active' : '' %>">
            <i data-lucide="video" class="nav-dd-item-icon"></i> AI Video
          </a>
          <a href="/automate-leads" class="nav-link <%= currentPage === 'automate-leads' ? 'active' : '' %>">
            <i data-lucide="users" class="nav-dd-item-icon"></i> Automate Leads
          </a>
        </div>
      </div>
      <a href="/pricing" class="nav-link <%= currentPage === 'pricing' ? 'active' : '' %>">Pricing</a>
      <a href="/about" class="nav-link <%= currentPage === 'about' ? 'active' : '' %>">About</a>
      <a href="/contact" class="nav-link <%= currentPage === 'contact' ? 'active' : '' %>">Contact</a>
    </nav>

    <!-- Right actions -->
    <div class="nav-actions">
      <% if (locals.user) { %>
        <div class="nav-user">
          <button class="nav-user-btn" aria-haspopup="true">
            <img src="<%= user.avatar_url || '/assets/default-avatar.png' %>" alt="<%= user.name %>" class="nav-avatar">
          </button>
          <div class="nav-user-menu">
            <a href="/dashboard" class="nav-user-link"><i data-lucide="layout-dashboard"></i> Dashboard</a>
            <a href="/profile" class="nav-user-link"><i data-lucide="user"></i> Profile</a>
            <hr class="nav-user-divider">
            <a href="/api/auth/signout" class="nav-user-link nav-user-logout"><i data-lucide="log-out"></i> Logout</a>
          </div>
        </div>
      <% } else { %>
        <a href="/login" class="nav-btn nav-btn-outline">Login</a>
        <a href="/register" class="nav-btn nav-btn-primary">Get Started</a>
      <% } %>

      <!-- Hamburger (mobile) -->
      <button class="nav-hamburger" id="navToggle" aria-label="Menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="nav-drawer" id="navDrawer" role="dialog" aria-modal="true">
    <div class="nav-drawer-overlay" id="navDrawerOverlay"></div>
    <div class="nav-drawer-body">
      <div class="nav-drawer-header">
        <img src="/assets/final logo dark.png" alt="Tak2ai" class="nav-logo-img">
        <button class="nav-drawer-close" id="navDrawerClose" aria-label="Close menu">
          <i data-lucide="x"></i>
        </button>
      </div>
      <nav class="nav-drawer-links">
        <a href="/" class="nav-link <%= currentPage === 'home' ? 'active' : '' %>">Home</a>
        <div class="nav-dd nav-dd-mobile">
          <button class="nav-link nav-dd-trigger">
            Services <i data-lucide="chevron-down" class="nav-dd-icon"></i>
          </button>
          <div class="nav-dd-menu">
            <a href="/voice-ai" class="nav-link <%= currentPage === 'voice-ai' ? 'active' : '' %>">
              <i data-lucide="phone" class="nav-dd-item-icon"></i> AI Voice Calling
            </a>
            <a href="/chatbot" class="nav-link <%= currentPage === 'chatbot' ? 'active' : '' %>">
              <i data-lucide="bot" class="nav-dd-item-icon"></i> AI Chatbot
            </a>
            <a href="/video-ai" class="nav-link <%= currentPage === 'video-ai' ? 'active' : '' %>">
              <i data-lucide="video" class="nav-dd-item-icon"></i> AI Video
            </a>
            <a href="/automate-leads" class="nav-link <%= currentPage === 'automate-leads' ? 'active' : '' %>">
              <i data-lucide="users" class="nav-dd-item-icon"></i> Automate Leads
            </a>
          </div>
        </div>
        <a href="/pricing" class="nav-link <%= currentPage === 'pricing' ? 'active' : '' %>">Pricing</a>
        <a href="/about" class="nav-link <%= currentPage === 'about' ? 'active' : '' %>">About</a>
        <a href="/contact" class="nav-link <%= currentPage === 'contact' ? 'active' : '' %>">Contact</a>
      </nav>
      <div class="nav-drawer-footer">
        <% if (locals.user) { %>
          <a href="/dashboard" class="nav-btn nav-btn-primary"><i data-lucide="layout-dashboard"></i> Dashboard</a>
          <a href="/api/auth/signout" class="nav-btn nav-btn-outline"><i data-lucide="log-out"></i> Logout</a>
        <% } else { %>
          <a href="/login" class="nav-btn nav-btn-outline">Login</a>
          <a href="/register" class="nav-btn nav-btn-primary">Get Started</a>
        <% } %>
      </div>
    </div>
  </div>
</header>
