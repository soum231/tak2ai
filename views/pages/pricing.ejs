        </table>
      </div>
      <div class="pricing-table-footer">
        <p><i data-lucide="info"></i> All recharges are one-time. Minutes never expire. GST additional.</p>
        <button class="btn btn-primary btn-block" id="openGsModalBtn"><i data-lucide="rocket"></i> Get Started Now</button>
      </div>
    </div>
  </div>
</section>

<section class="cta">
