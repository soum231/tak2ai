  <div class="container">
    <div class="animate-on-scroll">
      <h2 class="cta-title">Ready to transform <span class="heading-gradient">your business</span>?</h2>
      <p class="cta-desc">Start your AI automation journey today.</p>
      <div class="cta-buttons">
        <a href="https://wa.me/919088011999" target="_blank" class="btn btn-whatsapp"><i data-lucide="message-circle"></i> Chat on WhatsApp</a>
        <a href="/contact" class="btn btn-secondary"><i data-lucide="mail"></i> Contact Us</a>
