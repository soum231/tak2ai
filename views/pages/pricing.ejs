              <th>Total Minutes</th>
              <th>Pricing Per Min (₹)</th>
              <th>Earned Extra (₹)</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><span class="plan-badge">Best Value</span> ₹25,000</td>
              <td>4,545</td>
              <td><span class="rate-highlight">₹5.5</span></td>
