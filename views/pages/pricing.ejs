<%- include('../partials/head', { title: 'Pricing - Tak2ai', description: 'Transparent voice calling pricing. Recharge once, use forever. The more you recharge, the lower your per-minute rate.', canonical: '/pricing' }) %>
</head>
<body>

<%- include('../partials/navbar', { currentPage: 'pricing' }) %>

<section class="page-hero">
  <div class="hero-bg">
