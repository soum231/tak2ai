<%- include('../partials/head', { title: 'Admin Dashboard', description: 'Super admin dashboard for Tak2ai' }) %>
</head>
<body class="admin-layout">

<header class="admin-header">
  <h1>
    <span class="admin-logo-text">Tak2ai</span>
    Admin
    <span class="admin-badge">Super Admin</span>
  </h1>
  <div class="admin-header-right">
    <a href="/" target="_blank"><i data-lucide="external-link" style="width:16px;height:16px"></i> View Site</a>
    <a href="/api/auth/signout"><i data-lucide="log-out" style="width:16px;height:16px"></i> Sign Out</a>
  </div>
</header>

<div class="admin-body">
  <aside class="admin-sidebar">
    <a href="#" class="admin-sidebar-item active" onclick="switchTab('leads');return false"><i data-lucide="inbox" style="width:18px;height:18px"></i> Leads</a>
    <a href="#" class="admin-sidebar-item" onclick="switchTab('users');return false"><i data-lucide="users" style="width:18px;height:18px"></i> Users</a>
  </aside>

  <main class="admin-main">
    <!-- LEADS TAB -->
    <div id="tabLeads" class="admin-tab">
      <div class="admin-stats">
        <div class="admin-stat-card"><div class="stat-value" id="statTotal">—</div><div class="stat-label">Total Leads</div></div>
        <div class="admin-stat-card"><div class="stat-value" id="statNew">—</div><div class="stat-label">New</div></div>
        <div class="admin-stat-card"><div class="stat-value" id="statContacted">—</div><div class="stat-label">Contacted</div></div>
        <div class="admin-stat-card"><div class="stat-value" id="statConverted">—</div><div class="stat-label">Converted</div></div>
      </div>

      <div class="admin-toolbar">
        <div class="admin-search">
          <i data-lucide="search"></i>
          <input type="text" id="searchInput" placeholder="Search by name, email, or phone..." autocomplete="off">
        </div>
        <button class="btn btn-ghost" id="refreshBtn" style="padding:8px 16px;font-size:.85rem">
          <i data-lucide="refresh-cw" style="width:16px;height:16px"></i> Refresh
        </button>
      </div>

      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Category</th>
              <th>Message</th>
              <th>Status</th>
              <th>Date</th>
              <th style="width:80px">Actions</th>
            </tr>
          </thead>
          <tbody id="leadsBody">
            <tr><td colspan="8" style="text-align:center;padding:40px;color:var(--text-secondary)">Loading leads...</td></tr>
          </tbody>
        </table>
        <div class="admin-pagination" id="pagination"></div>
      </div>
    </div>

    <!-- USERS TAB -->
    <div id="tabUsers" class="admin-tab" style="display:none">
      <div class="admin-stats">
        <div class="admin-stat-card"><div class="stat-value" id="uStatTotal">—</div><div class="stat-label">Total Users</div></div>
        <div class="admin-stat-card"><div class="stat-value" id="uStatRecharged">—</div><div class="stat-label">Recharged Users</div></div>
        <div class="admin-stat-card"><div class="stat-value" id="uStatMinutes">—</div><div class="stat-label">Total Minutes</div></div>
        <div class="admin-stat-card"><div class="stat-value" id="uStatRevenue">—</div><div class="stat-label">Total Revenue</div></div>
      </div>

      <div class="admin-toolbar">
        <div class="admin-search">
          <i data-lucide="search"></i>
          <input type="text" id="userSearchInput" placeholder="Search users..." autocomplete="off">
        </div>
        <button class="btn btn-ghost" onclick="fetchUsers()" style="padding:8px 16px;font-size:.85rem">
          <i data-lucide="refresh-cw" style="width:16px;height:16px"></i> Refresh
        </button>
      </div>

      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Company</th>
              <th>Phone</th>
              <th>Balance (min)</th>
              <th>Used</th>
              <th>Adjust</th>
              <th>Total Recharged</th>
              <th>Recharges</th>
              <th>Last Recharge</th>
              <th style="width:100px">Actions</th>
            </tr>
          </thead>
          <tbody id="usersBody">
            <tr><td colspan="9" style="text-align:center;padding:40px;color:var(--text-secondary)">Loading users...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<!-- EDIT LEAD MODAL -->
<div class="admin-overlay" id="editModal">
  <div class="admin-modal">
    <h2>Edit Lead</h2>
    <p class="sub" id="editLeadInfo">Editing lead</p>
    <div class="form-group">
      <label>Status</label>
      <select id="editStatus">
        <option value="new">New</option>
        <option value="contacted">Contacted</option>
        <option value="qualified">Qualified</option>
        <option value="converted">Converted</option>
        <option value="closed">Closed</option>
      </select>
    </div>
    <div class="form-group">
      <label>Notes</label>
      <textarea id="editNotes" rows="3" placeholder="Add internal notes..."></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeEditModal()">Cancel</button>
      <button class="btn btn-primary" id="saveEditBtn">Save Changes</button>
    </div>
  </div>
</div>

<!-- DELETE LEAD MODAL -->
<div class="admin-overlay" id="deleteModal">
  <div class="admin-modal">
    <h2>Delete Lead</h2>
    <p class="sub">Are you sure you want to delete <strong id="deleteLeadName">this lead</strong>? This cannot be undone.</p>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeDeleteModal()">Cancel</button>
      <button class="btn btn-primary" id="confirmDeleteBtn" style="background:#ff5050;border-color:#ff5050">Delete</button>
    </div>
  </div>
</div>

<!-- RECHARGE MODAL -->
<div class="admin-overlay" id="rechargeModal">
  <div class="admin-modal">
    <h2>Add Recharge</h2>
    <p class="sub" id="rechargeUserInfo">Adding recharge for user</p>
    <div class="form-group">
      <label>Minutes <span style="font-size:.75rem;color:var(--text-tertiary)">(use negative value to deduct)</span></label>
      <input type="number" id="rechargeMinutes" step="1" placeholder="e.g. 10000">
    </div>
    <div class="form-group">
      <label>Amount Paid (₹)</label>
      <input type="number" id="rechargeAmount" min="0" step="0.01" placeholder="e.g. 25000">
    </div>
    <div class="form-group">
      <label>Notes</label>
      <textarea id="rechargeNotes" rows="2" placeholder="Optional notes..."></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeRechargeModal()">Cancel</button>
      <button class="btn btn-primary" id="saveRechargeBtn">Add Recharge</button>
    </div>
  </div>
</div>

<!-- ADJUSTMENT MODAL -->
<div class="admin-overlay" id="adjustmentModal">
  <div class="admin-modal">
    <h2>Set Used Minutes Adjustment</h2>
    <p class="sub" id="adjUserInfo">Setting adjustment for user</p>
    <div class="form-group">
      <label>Extra Used Minutes <span style="font-size:.75rem;color:var(--text-tertiary)">(positive = reduce balance, negative = increase balance)</span></label>
      <input type="number" id="adjMinutes" step="0.01" placeholder="e.g. 14.05">
      <p style="font-size:.75rem;color:var(--text-secondary);margin-top:4px">Adds to the used minutes from call reports. Set to 0 to reset.</p>
    </div>
    <div class="form-group">
      <label>Reason / Notes</label>
      <textarea id="adjNotes" rows="2" placeholder="Why was this adjustment made?"></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeAdjustmentModal()">Cancel</button>
      <button class="btn btn-primary" id="saveAdjBtn">Save</button>
    </div>
  </div>
</div>

<!-- ACTIVITY LOG MODAL -->
<div class="admin-overlay" id="activityModal">
  <div class="admin-modal" style="max-width:700px">
    <h2>Activity Log</h2>
    <p class="sub" id="activityUserInfo">Showing activity for user</p>
    <div id="activityLogBody" style="max-height:400px;overflow-y:auto">
      <p style="text-align:center;padding:40px;color:var(--text-secondary)">Loading activities...</p>
    </div>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="closeActivityLog()">Close</button>
    </div>
  </div>
</div>

<div class="admin-toast" id="toast"></div>

<script src="https://unpkg.com/lucide@latest"></script>
<script>
let currentPage = 1;
let leadsData = [];
let editingId = null;
let deletingId = null;
let rechargingUserId = null;
let rechargingUserName = '';
let usersData = [];

function showToast(msg, type) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'admin-toast ' + type + ' show';
  setTimeout(() => t.classList.remove('show'), 3000);
}

function formatDate(iso) {
  if (!iso) return '—';
  const d = new Date(iso);
  return d.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

function truncate(s, n) {
  if (!s) return '—';
  return s.length > n ? s.substring(0, n) + '\u2026' : s;
}

function esc(s) {
  if (!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// Tab switching
function switchTab(tab) {
  document.querySelectorAll('.admin-tab').forEach(t => t.style.display = 'none');
  document.querySelectorAll('.admin-sidebar-item').forEach(i => i.classList.remove('active'));
  document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).style.display = '';
  event.target.classList.add('active');
  if (tab === 'users') fetchUsers();
}

// ========== LEADS ==========

async function fetchLeads(page) {
  currentPage = page || 1;
  const tbody = document.getElementById('leadsBody');
  tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--text-secondary)">Loading leads...</td></tr>';

  try {
    const res = await fetch('/api/leads?page=' + currentPage + '&limit=20');
    const json = await res.json();
    if (!json.success) throw new Error(json.error);
    leadsData = json.data;
    renderLeads(leadsData);
    renderPagination(json.pagination);
    updateLeadStats(leadsData, json.pagination);
  } catch (err) {
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:#ff5050">Error: ' + err.message + '</td></tr>';
  }
}

function renderLeads(leads) {
  const tbody = document.getElementById('leadsBody');
  if (!leads || leads.length === 0) {
    tbody.innerHTML = '<tr><td colspan="8"><div class="admin-empty"><i data-lucide="inbox" style="width:48px;height:48px;opacity:.3"></i><h3>No leads yet</h3><p style="color:var(--text-secondary);font-size:.85rem">Customer submissions will appear here.</p></div></td></tr>';
    return;
  }
  tbody.innerHTML = leads.map(l => {
    const statusClass = 'status-' + (l.status || 'new');
    return '<tr>' +
      '<td><strong>' + esc(l.name) + '</strong></td>' +
      '<td><a href="mailto:' + esc(l.email) + '" style="color:var(--primary);text-decoration:none">' + esc(l.email) + '</a></td>' +
      '<td>' + esc(l.phone) + '</td>' +
      '<td>' + esc(l.category || '\u2014') + '</td>' +
      '<td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="' + esc(l.message || '') + '">' + truncate(l.message, 30) + '</td>' +
      '<td><span class="status-badge ' + statusClass + '">' + esc(l.status || 'new') + '</span></td>' +
      '<td style="white-space:nowrap;font-size:.8rem;color:var(--text-secondary)">' + formatDate(l.created_at) + '</td>' +
      '<td><div class="admin-cell-actions">' +
        '<button class="admin-btn-icon" onclick="openEdit(\'' + l.id + '\')" title="Edit"><i data-lucide="pencil" style="width:16px;height:16px"></i></button>' +
        '<button class="admin-btn-icon danger" onclick="openDelete(\'' + l.id + '\')" title="Delete"><i data-lucide="trash-2" style="width:16px;height:16px"></i></button>' +
      '</div></td>' +
    '</tr>';
  }).join('');
  lucide.createIcons();
}

function renderPagination(p) {
  const el = document.getElementById('pagination');
  if (!p || p.total_pages <= 1) { el.innerHTML = ''; return; }
  el.innerHTML =
    '<button onclick="fetchLeads(' + (currentPage - 1) + ')" ' + (currentPage <= 1 ? 'disabled' : '') + '>Previous</button>' +
    '<span class="page-info">Page ' + currentPage + ' of ' + p.total_pages + '</span>' +
    '<button onclick="fetchLeads(' + (currentPage + 1) + ')" ' + (currentPage >= p.total_pages ? 'disabled' : '') + '>Next</button>';
}

function updateLeadStats(leads, pagination) {
  const total = pagination ? pagination.total : leads.length;
  animateNumber('statTotal', total);
  animateNumber('statNew', leads.filter(l => l.status === 'new').length);
  animateNumber('statContacted', leads.filter(l => l.status === 'contacted').length);
  animateNumber('statConverted', leads.filter(l => l.status === 'converted').length);
}

function animateNumber(id, val) {
  const el = document.getElementById(id);
  el.textContent = val;
}

function openEdit(id) {
  const lead = leadsData.find(l => l.id === id);
  if (!lead) return;
  editingId = id;
  document.getElementById('editLeadInfo').textContent = lead.name + ' (' + lead.email + ')';
  document.getElementById('editStatus').value = lead.status || 'new';
  document.getElementById('editNotes').value = lead.notes || '';
  document.getElementById('editModal').classList.add('open');
}

function closeEditModal() { document.getElementById('editModal').classList.remove('open'); editingId = null; }

document.getElementById('saveEditBtn').addEventListener('click', async function () {
  if (!editingId) return;
  const status = document.getElementById('editStatus').value;
  const notes = document.getElementById('editNotes').value.trim();
  this.disabled = true; this.textContent = 'Saving...';
  try {
    const res = await fetch('/api/leads/' + editingId, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status, notes: notes || null }) });
    const json = await res.json();
    if (!json.success) throw new Error(json.error);
    showToast('Lead updated', 'success'); closeEditModal(); fetchLeads(currentPage);
  } catch (err) { showToast('Error: ' + err.message, 'error');
  } finally { this.disabled = false; this.textContent = 'Save Changes'; }
});

function openDelete(id) {
  const lead = leadsData.find(l => l.id === id);
  if (!lead) return;
  deletingId = id;
  document.getElementById('deleteLeadName').textContent = lead.name;
  document.getElementById('deleteModal').classList.add('open');
}

function closeDeleteModal() { document.getElementById('deleteModal').classList.remove('open'); deletingId = null; }

document.getElementById('confirmDeleteBtn').addEventListener('click', async function () {
  if (!deletingId) return;
  this.disabled = true; this.textContent = 'Deleting...';
  try {
    const res = await fetch('/api/leads/' + deletingId, { method: 'DELETE' });
    const json = await res.json();
    if (!json.success) throw new Error(json.error);
    showToast('Lead deleted', 'success'); closeDeleteModal(); fetchLeads(currentPage);
  } catch (err) { showToast('Error: ' + err.message, 'error');
  } finally { this.disabled = false; this.textContent = 'Delete'; }
});

document.getElementById('searchInput').addEventListener('input', function () {
  const q = this.value.toLowerCase().trim();
  renderLeads(leadsData.filter(l =>
    (l.name && l.name.toLowerCase().includes(q)) ||
    (l.email && l.email.toLowerCase().includes(q)) ||
    (l.phone && l.phone.includes(q))
  ));
});

document.getElementById('refreshBtn').addEventListener('click', function () {
  document.getElementById('searchInput').value = ''; fetchLeads(1);
});

// ========== USERS ==========

async function fetchUsers() {
  const tbody = document.getElementById('usersBody');
    tbody.innerHTML = '<tr><td colspan="11" style="text-align:center;padding:40px;color:var(--text-secondary)">Loading users...</td></tr>';
  try {
    const res = await fetch('/api/admin/users');
    const json = await res.json();
    if (!json.success) throw new Error(json.error);
    usersData = json.data;
    renderUsers(usersData);
    updateUserStats(usersData);
  } catch (err) {
    tbody.innerHTML = '<tr><td colspan="9" style="text-align:center;padding:40px;color:#ff5050">Error: ' + err.message + '</td></tr>';
  }
}

function renderUsers(users) {
  const tbody = document.getElementById('usersBody');
  if (!users || users.length === 0) {
    tbody.innerHTML = '<tr><td colspan="11"><div class="admin-empty"><i data-lucide="users" style="width:48px;height:48px;opacity:.3"></i><h3>No users yet</h3></div></td></tr>';
    return;
  }
  tbody.innerHTML = users.map(u => {
    const bal = u.balance_minutes || 0;
    const recharged = u.total_recharged || 0;
    const adminBadge = u.is_admin ? ' <span class="admin-badge" style="font-size:.6rem;padding:1px 6px;margin-left:4px">ADMIN</span>' : '';
    const adj = u.used_adjustment || 0;
    return '<tr>' +
      '<td><strong>' + esc(u.name || 'Unknown') + adminBadge + '</strong></td>' +
      '<td style="font-size:.8rem;color:var(--text-secondary)">' + esc(u.email || '\u2014') + '</td>' +
      '<td>' + esc(u.company || '\u2014') + '</td>' +
      '<td>' + esc(u.phone || '\u2014') + '</td>' +
      '<td><strong style="color:var(--primary)">' + bal.toLocaleString() + ' min</strong></td>' +
      '<td style="font-size:.8rem;color:var(--text-secondary)">' + (u.used_minutes || 0).toLocaleString() + ' min</td>' +
      '<td><span class="adj-value" id="adj-' + u.id + '">' + adj.toLocaleString() + '</span> <button class="admin-btn-icon" onclick="openAdjustment(\'' + u.id + '\',\'' + esc(u.name || 'Unknown').replace(/'/g,"\\'") + '\',' + adj + ')" title="Set used adjustment" style="color:#ffb700;border-color:rgba(255,200,0,.3);font-size:.7rem;padding:2px 5px"><i data-lucide="sliders" style="width:12px;height:12px"></i></button></td>' +
      '<td>\u20B9 ' + recharged.toLocaleString() + '</td>' +
      '<td>' + (u.recharge_count || 0) + '</td>' +
      '<td style="font-size:.8rem;color:var(--text-secondary)">' + formatDate(u.last_recharge) + '</td>' +
      '<td><div class="admin-cell-actions">' +
        '<button class="admin-btn-icon" onclick="openRecharge(\'' + u.id + '\',\'' + esc(u.name || 'Unknown').replace(/'/g,"\\'") + '\')" title="Recharge" style="color:var(--secondary);border-color:rgba(124,255,107,.3)"><i data-lucide="plus-circle" style="width:16px;height:16px"></i></button>' +
        '<button class="admin-btn-icon" onclick="openActivityLog(\'' + u.id + '\',\'' + esc(u.name || 'Unknown').replace(/'/g,"\\'") + '\')" title="Activity Log" style="color:var(--primary);border-color:rgba(0,229,255,.3)"><i data-lucide="clock" style="width:16px;height:16px"></i></button>' +
      '</div></td>' +
    '</tr>';
  }).join('');
  lucide.createIcons();
}

function updateUserStats(users) {
  animateNumber('uStatTotal', users.length);
  const recharged = users.filter(u => (u.recharge_count || 0) > 0).length;
  animateNumber('uStatRecharged', recharged);
  const totalMin = users.reduce((s, u) => s + (u.balance_minutes || 0), 0);
  animateNumber('uStatMinutes', totalMin.toLocaleString());
  const totalRev = users.reduce((s, u) => s + (u.total_recharged || 0), 0);
  animateNumber('uStatRevenue', '\u20B9 ' + totalRev.toLocaleString());
}

document.getElementById('userSearchInput').addEventListener('input', function () {
  const q = this.value.toLowerCase().trim();
  renderUsers(usersData.filter(u =>
    (u.name && u.name.toLowerCase().includes(q)) ||
    (u.company && u.company.toLowerCase().includes(q)) ||
    (u.phone && u.phone.includes(q))
  ));
});

// ========== RECHARGE ==========

function openRecharge(userId, userName) {
  rechargingUserId = userId;
  rechargingUserName = userName;
  document.getElementById('rechargeUserInfo').textContent = 'Adding recharge for ' + userName;
  document.getElementById('rechargeMinutes').value = '';
  document.getElementById('rechargeAmount').value = '';
  document.getElementById('rechargeNotes').value = '';
  document.getElementById('rechargeModal').classList.add('open');
}

function closeRechargeModal() {
  document.getElementById('rechargeModal').classList.remove('open');
  rechargingUserId = null;
}

document.getElementById('saveRechargeBtn').addEventListener('click', async function () {
  if (!rechargingUserId) return;
  const minutes = document.getElementById('rechargeMinutes').value;
  const amount = document.getElementById('rechargeAmount').value;
  const notes = document.getElementById('rechargeNotes').value.trim();
  if (!minutes || parseInt(minutes) === 0) {
    showToast('Please enter valid minutes', 'error'); return;
  }
  this.disabled = true; this.textContent = 'Adding...';
  try {
    const res = await fetch('/api/admin/recharges', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user_id: rechargingUserId, user_name: rechargingUserName, minutes: parseInt(minutes), amount: parseFloat(amount) || 0, notes })
    });
    const json = await res.json();
    if (!json.success) throw new Error(json.error);
    showToast('Recharge added: ' + parseInt(minutes) + ' min', 'success');
    closeRechargeModal();
    fetchUsers();
  } catch (err) { showToast('Error: ' + err.message, 'error');
  } finally { this.disabled = false; this.textContent = 'Add Recharge'; }
});

// ========== ADJUSTMENT ==========

let adjustingUserId = null;
let adjustingUserName = '';

function openAdjustment(userId, userName, currentAdj) {
  adjustingUserId = userId;
  adjustingUserName = userName;
  document.getElementById('adjUserInfo').textContent = 'Setting used minutes adjustment for ' + userName;
  document.getElementById('adjMinutes').value = currentAdj || '';
  document.getElementById('adjustmentModal').classList.add('open');
}

function closeAdjustmentModal() {
  document.getElementById('adjustmentModal').classList.remove('open');
  adjustingUserId = null;
}

document.getElementById('saveAdjBtn').addEventListener('click', async function () {
  if (!adjustingUserId) return;
  const minutes = document.getElementById('adjMinutes').value;
  const notes = document.getElementById('adjNotes').value.trim();
  if (minutes === '' || isNaN(parseFloat(minutes))) {
    showToast('Please enter a valid number', 'error'); return;
  }
  this.disabled = true; this.textContent = 'Saving...';
  try {
    const res = await fetch('/api/admin/users/adjustment', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user_id: adjustingUserId, user_name: adjustingUserName, minutes: parseFloat(minutes) || 0, notes })
    });
    const json = await res.json();
    if (!json.success) throw new Error(json.error);
    const el = document.getElementById('adj-' + adjustingUserId);
    if (el) el.textContent = (parseFloat(minutes) || 0).toLocaleString();
    showToast('Adjustment set to ' + (parseFloat(minutes) || 0) + ' min', 'success');
    closeAdjustmentModal();
    fetchUsers();
  } catch (err) { showToast('Error: ' + err.message, 'error');
  } finally { this.disabled = false; this.textContent = 'Save'; }
});

// ========== ACTIVITY LOG ==========

let activityUserId = null;

function openActivityLog(userId, userName) {
  activityUserId = userId;
  document.getElementById('activityUserInfo').textContent = 'Showing activity for ' + userName;
  document.getElementById('activityLogBody').innerHTML = '<p style="text-align:center;padding:40px;color:var(--text-secondary)">Loading activities...</p>';
  document.getElementById('activityModal').classList.add('open');
  fetchActivities(userId);
}

function closeActivityLog() {
  document.getElementById('activityModal').classList.remove('open');
  activityUserId = null;
}

async function fetchActivities(userId) {
  const el = document.getElementById('activityLogBody');
  try {
    const res = await fetch('/api/admin/activities?user_id=' + userId);
    const json = await res.json();
    if (!json.success) throw new Error(json.error);
    if (!json.data || json.data.length === 0) {
      el.innerHTML = '<div class="admin-empty"><i data-lucide="clock" style="width:48px;height:48px;opacity:.3"></i><h3>No activity yet</h3></div>';
      return;
    }
    el.innerHTML = '<div style="display:flex;flex-direction:column;gap:8px">' + json.data.map(function (a) {
      const isRecharge = a.type === 'recharge';
      const isDeduction = a.type === 'deduction';
      const isAdjustment = a.type === 'adjustment';
      const icon = isRecharge ? 'plus-circle' : isDeduction ? 'minus-circle' : 'sliders';
      const color = isRecharge ? 'var(--secondary)' : isDeduction ? '#ff5050' : '#ffb700';
      const typeLabel = isRecharge ? 'Recharge' : isDeduction ? 'Deduction' : 'Adjustment';
      const minStr = a.minutes ? (isDeduction ? '' : '') + a.minutes + ' min' : '';
      const amtStr = a.amount ? '\u20B9 ' + Number(a.amount).toLocaleString() : '';
      const detail = [typeLabel, minStr, amtStr].filter(Boolean).join(' \u2022 ');
      const d = new Date(a.created_at);
      const dateStr = d.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
      return '<div style="display:flex;gap:12px;padding:12px 16px;background:var(--bg-primary);border-radius:var(--radius-md);border:1px solid var(--border-color);align-items:flex-start">' +
        '<div style="flex-shrink:0;width:32px;height:32px;border-radius:var(--radius-sm);background:' + color + '15;display:flex;align-items:center;justify-content:center;color:' + color + '"><i data-lucide="' + icon + '" style="width:16px;height:16px"></i></div>' +
        '<div style="flex:1;min-width:0">' +
          '<div style="font-weight:600;font-size:.85rem">' + detail + '</div>' +
          (a.notes ? '<div style="font-size:.8rem;color:var(--text-secondary);margin-top:2px">' + esc(a.notes) + '</div>' : '') +
          '<div style="font-size:.75rem;color:var(--text-tertiary);margin-top:2px">' + dateStr + (a.created_by ? ' \u00B7 by ' + a.created_by : '') + '</div>' +
        '</div></div>';
    }).join('') + '</div>';
    if (window.lucide) lucide.createIcons();
  } catch (err) {
    el.innerHTML = '<p style="text-align:center;padding:40px;color:#ff5050">Error: ' + esc(err.message) + '</p>';
  }
}

// ========== EVENTS ==========

document.getElementById('editModal').addEventListener('click', function (e) { if (e.target === this) closeEditModal(); });
document.getElementById('deleteModal').addEventListener('click', function (e) { if (e.target === this) closeDeleteModal(); });
document.getElementById('rechargeModal').addEventListener('click', function (e) { if (e.target === this) closeRechargeModal(); });
document.getElementById('adjustmentModal').addEventListener('click', function (e) { if (e.target === this) closeAdjustmentModal(); });
document.getElementById('activityModal').addEventListener('click', function (e) { if (e.target === this) closeActivityLog(); });
document.addEventListener('keydown', function (e) { if (e.key === 'Escape') { closeEditModal(); closeDeleteModal(); closeRechargeModal(); closeAdjustmentModal(); closeActivityLog(); } });

fetchLeads(1);
</script>
</body>
</html>
