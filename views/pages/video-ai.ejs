      <div class="template-card animate-on-scroll"><div class="tmpl-preview"><i data-lucide="book-open"></i></div><div class="tmpl-info"><h4>Educational</h4><p>Tutorial-style with screen recording overlay</p></div></div>
      <div class="template-card animate-on-scroll"><div class="tmpl-preview"><i data-lucide="briefcase"></i></div><div class="tmpl-info"><h4>Corporate</h4><p>Professional announcement with brand kit</p></div></div>
