<%- include('../partials/head', { title: 'Reset Password', description: 'Reset your Tak2ai account password.', canonical: '/forgot-password' }) %>
</head>
<body class="auth-page">

<%- include('../partials/navbar', { currentPage: 'forgot-password' }) %>

<div class="auth-hero">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <div class="container">
    <div class="auth-card">
      <div class="auth-card-header">
        <a href="/" class="auth-logo"><img src="/assets/final logo dark.png" alt="Tak2ai"></a>
        <h1>Reset Password</h1>
        <p>Enter your email and we'll send you a reset link</p>
      </div>

      <form class="auth-form" id="forgotForm" autocomplete="off">
        <div class="form-group">
          <label for="forgotEmail">Email Address</label>
          <div class="input-group">
            <span class="input-icon"><i data-lucide="mail"></i></span>
            <input type="email" id="forgotEmail" name="email" placeholder="you@example.com" required autocomplete="email">
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-block" id="forgotBtn">
          <span class="btn-text">Send Reset Link</span>
          <span class="btn-loader" style="display:none"><i data-lucide="loader-2" class="spin"></i></span>
        </button>
        <div class="auth-error" id="forgotError" style="display:none"></div>
        <div class="auth-success" id="forgotSuccess" style="display:none"></div>
      </form>

      <div class="auth-footer">
        Remember your password? <a href="/login" class="auth-link">Sign In</a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const forgotForm = document.getElementById('forgotForm');
  const forgotBtn = document.getElementById('forgotBtn');
  const forgotError = document.getElementById('forgotError');
  const forgotSuccess = document.getElementById('forgotSuccess');

  forgotForm.addEventListener('submit', async function(e) {
    e.preventDefault();
    forgotError.style.display = 'none';
    forgotSuccess.style.display = 'none';
    forgotBtn.querySelector('.btn-text').style.display = 'none';
    forgotBtn.querySelector('.btn-loader').style.display = 'inline-flex';
    forgotBtn.disabled = true;

    const email = document.getElementById('forgotEmail').value;
    try {
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      const data = await res.json();
      if (data.success) {
        forgotSuccess.textContent = data.message || 'Reset link sent! Check your email.';
        forgotSuccess.style.display = 'block';
        forgotForm.reset();
      } else {
        forgotError.textContent = data.error || 'Failed to send reset link';
        forgotError.style.display = 'block';
      }
    } catch {
      forgotError.textContent = 'Something went wrong. Please try again.';
      forgotError.style.display = 'block';
    } finally {
      forgotBtn.querySelector('.btn-text').style.display = 'inline';
      forgotBtn.querySelector('.btn-loader').style.display = 'none';
      forgotBtn.disabled = false;
    }
  });
});
</script>

</body>
</html>
