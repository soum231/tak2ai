<%- include('../partials/head', { title: 'Set New Password', description: 'Set a new password for your Tak2ai account.', canonical: '/reset-password' }) %>
</head>
<body class="auth-page">

<%- include('../partials/navbar', { currentPage: 'reset-password' }) %>

<div class="auth-hero">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <div class="container">
    <div class="auth-card">
      <div class="auth-card-header">
        <a href="/" class="auth-logo"><img src="/assets/final logo dark.png" alt="Tak2ai"></a>
        <h1>Set New Password</h1>
        <p>Enter your new password below</p>
      </div>

      <div id="resetLoading" style="text-align:center;padding:32px 0;color:var(--text-secondary)">
        <i data-lucide="loader-2" class="spin" style="width:32px;height:32px;color:var(--primary)"></i>
        <p style="margin-top:12px;font-size:.9rem">Verifying reset link...</p>
      </div>

      <div id="resetError" style="display:none;text-align:center;padding:24px 0">
        <div style="font-size:2.5rem;margin-bottom:12px">&#x26A0;</div>
        <p style="color:var(--text-secondary);margin-bottom:20px" id="resetErrorMsg">Invalid or expired reset link.</p>
        <a href="/forgot-password" class="btn btn-primary">Request New Link</a>
      </div>

      <form class="auth-form" id="resetForm" style="display:none" autocomplete="off">
        <div class="form-group">
          <label for="newPassword">New Password</label>
          <div class="input-group">
            <span class="input-icon"><i data-lucide="lock"></i></span>
            <input type="password" id="newPassword" name="password" placeholder="Enter new password" required minlength="6" autocomplete="new-password">
            <button type="button" class="password-toggle" id="pwToggleNew" aria-label="Toggle password visibility" tabindex="-1">
              <i data-lucide="eye"></i>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label for="confirmPassword">Confirm Password</label>
          <div class="input-group">
            <span class="input-icon"><i data-lucide="lock"></i></span>
            <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm new password" required minlength="6" autocomplete="new-password">
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-block" id="resetBtn">
          <span class="btn-text">Update Password</span>
          <span class="btn-loader" style="display:none"><i data-lucide="loader-2" class="spin"></i></span>
        </button>
        <div class="auth-error" id="resetFormError" style="display:none"></div>
        <div class="auth-success" id="resetFormSuccess" style="display:none"></div>
      </form>

      <div class="auth-footer" id="resetFooter" style="display:none">
        <a href="/login" class="auth-link">Back to Sign In</a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const resetLoading = document.getElementById('resetLoading');
  const resetError = document.getElementById('resetError');
  const resetErrorMsg = document.getElementById('resetErrorMsg');
  const resetForm = document.getElementById('resetForm');
  const resetFooter = document.getElementById('resetFooter');
  const resetFormError = document.getElementById('resetFormError');
  const resetFormSuccess = document.getElementById('resetFormSuccess');
  const resetBtn = document.getElementById('resetBtn');

  const hash = window.location.hash;
  const params = new URLSearchParams(hash.substring(1));
  const accessToken = params.get('access_token');
  const refreshToken = params.get('refresh_token');

  if (!accessToken || !refreshToken) {
    resetLoading.style.display = 'none';
    resetError.style.display = 'block';
    return;
  }

  const supabase = window.supabase.createClient(
    'https://nxxyxgsebtfuotrcothb.supabase.co',
    'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im54eHl4Z3NlYnRmdW90cmNvdGhiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEzMTgyNDgsImV4cCI6MjA5Njg5NDI0OH0.qwI6FU2rXxoV19gZf7fvjoCwQ86UMTkUqspRveDyIUQ'
  );

  supabase.auth.setSession({
    access_token: accessToken,
    refresh_token: refreshToken
  }).then(({ error }) => {
    resetLoading.style.display = 'none';
    if (error) {
      resetErrorMsg.textContent = 'Invalid or expired reset link.';
      resetError.style.display = 'block';
    } else {
      resetForm.style.display = 'block';
      resetFooter.style.display = 'block';
      lucide.createIcons();
    }
  });

  document.getElementById('pwToggleNew').addEventListener('click', function() {
    const input = document.getElementById('newPassword');
    const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
    input.setAttribute('type', type);
    this.querySelector('i').setAttribute('data-lucide', type === 'password' ? 'eye' : 'eye-off');
    lucide.createIcons();
  });

  resetForm.addEventListener('submit', async function(e) {
    e.preventDefault();
    resetFormError.style.display = 'none';
    resetFormSuccess.style.display = 'none';

    const pw = document.getElementById('newPassword').value;
    const confirm = document.getElementById('confirmPassword').value;

    if (pw !== confirm) {
      resetFormError.textContent = 'Passwords do not match';
      resetFormError.style.display = 'block';
      return;
    }

    resetBtn.querySelector('.btn-text').style.display = 'none';
    resetBtn.querySelector('.btn-loader').style.display = 'inline-flex';
    resetBtn.disabled = true;

    const { error } = await supabase.auth.updateUser({ password: pw });

    if (error) {
      resetFormError.textContent = error.message || 'Failed to update password';
      resetFormError.style.display = 'block';
    } else {
      resetFormSuccess.textContent = 'Password updated! Redirecting to sign in...';
      resetFormSuccess.style.display = 'block';
      resetForm.reset();
      setTimeout(function() { window.location.href = '/login'; }, 2000);
    }

    resetBtn.querySelector('.btn-text').style.display = 'inline';
    resetBtn.querySelector('.btn-loader').style.display = 'none';
    resetBtn.disabled = false;
  });
});
</script>

</body>
</html>
