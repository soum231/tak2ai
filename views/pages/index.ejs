<script>
(function() {
  var integrations = [
    { name: 'WhatsApp', id: 'whatsapp', color: '#25D366' },
    { name: 'HubSpot', id: 'hubspot', color: '#FF7A59' },
    { name: 'Salesforce', id: 'salesforce', color: '#00A1E0' },
    { name: 'Google Sheets', id: 'googlesheets', color: '#0F9D58' },
    { name: 'Zapier', id: 'zapier', color: '#FF4A00' },
    { name: 'Stripe', id: 'stripe', color: '#635BFF' },
    { name: 'Calendly', id: 'calendly', color: '#006BFF' },
    { name: 'PostgreSQL', id: 'postgresql', color: '#336791' }
  ];

  var visual = document.getElementById('intVisual');
  var cardsContainer = document.getElementById('intCards');
  var svg = document.getElementById('intSvg');
  if (!visual || !cardsContainer || !svg) return;

  var cardEls = [];
  integrations.forEach(function(item) {
    var card = document.createElement('div');
    card.className = 'int-card';
    card.innerHTML = '<img src="https://cdn.simpleicons.org/' + item.id + '/' + encodeURIComponent(item.color) + '" alt="' + item.name + '" onerror="this.style.display=\'none\'">' + item.name;
    cardsContainer.appendChild(card);
    cardEls.push(card);
  });

  function layout() {
    var rect = visual.getBoundingClientRect();
    var cx = rect.width / 2;
    var n = cardEls.length;
    var isMobile = rect.width < 768;
    var totalWidth = isMobile ? rect.width * 0.94 : Math.min(rect.width * 0.88, 900);
    var spacing = totalWidth / (n - 1);
    var startX = (rect.width - totalWidth) / 2;
    var cardY = isMobile ? 10 : rect.height * 0.06;
    var hubY = isMobile ? rect.height * 0.82 : rect.height * 0.80;
    var zigzagAmt = isMobile ? 32 : 55;

    svg.innerHTML = '';

    var defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
    var grad = document.createElementNS('http://www.w3.org/2000/svg', 'linearGradient');
    grad.id = 'intGrad';
    grad.setAttribute('x1', '0');
    grad.setAttribute('y1', '0');
    grad.setAttribute('x2', '0');
    grad.setAttribute('y2', '1');
    var stop1 = document.createElementNS('http://www.w3.org/2000/svg', 'stop');
    stop1.setAttribute('offset', '0%');
    stop1.setAttribute('stop-color', 'rgba(0,229,255,0.25)');
    var stop2 = document.createElementNS('http://www.w3.org/2000/svg', 'stop');
    stop2.setAttribute('offset', '100%');
    stop2.setAttribute('stop-color', 'rgba(0,229,255,0.05)');
    grad.appendChild(stop1);
    grad.appendChild(stop2);
    defs.appendChild(grad);
    svg.appendChild(defs);

    cardEls.forEach(function(card, i) {
      var cardW = card.offsetWidth || 140;
      var cardH = card.offsetHeight || 48;
      var x = startX + i * spacing;
      var zigzag = (i % 2 === 0) ? 0 : zigzagAmt;
      var cy = cardY + zigzag;
      card.style.left = (x - cardW / 2) + 'px';
      card.style.top = cy + 'px';

      var x1 = x;
      var y1 = cy + cardH + 6;
      var x2 = cx;
      var y2 = hubY;
      var cpx1 = x1 + (x2 - x1) * 0.3;
      var cpy1 = y1 + (y2 - y1) * 0.25;
      var cpx2 = x1 + (x2 - x1) * 0.7;
      var cpy2 = y2 - (y2 - y1) * 0.15;

      var d = 'M' + x1 + ',' + y1 + ' C' + cpx1 + ',' + cpy1 + ' ' + cpx2 + ',' + cpy2 + ' ' + x2 + ',' + y2;

      var glow = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      glow.setAttribute('d', d);
      glow.classList.add('int-connector-glow');
      svg.appendChild(glow);

      var path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', d);
      path.classList.add('int-connector');
      svg.appendChild(path);
    });
  }

  setTimeout(layout, 100);
  window.addEventListener('resize', layout);
})();
</script>

<%- include('../partials/scripts') %>

